{
  "name": "fitsync-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,dashboard -c blue,magenta \"bun run dev:server\" \"bun run dev:dashboard\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/src/index.ts",
    "dev:dashboard": "vite --config apps/dashboard/vite.config.ts",
    "build": "bun run build:dashboard && bun run build:marketing && bun run build:server",
    "build:dashboard": "vite build --config apps/dashboard/vite.config.ts",
    "build:marketing": "vite build --config apps/marketing/vite.config.ts --outDir dist/client --ssrManifest && vite build --config apps/marketing/vite.config.ts --ssr src/entry-server.tsx --outDir dist/server",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "build:server": "esbuild server/src/index.ts --bundle --platform=node --format=esm --outfile=server/dist/index.js --packages=external --tsconfig=server/tsconfig.json",
    "start": "cross-env NODE_ENV=production node server/dist/index.js",
    "lint": "eslint .",
    "db:migrate": "tsx server/src/db/migrate.ts",
    "db:seed": "tsx server/src/db/seed.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "i18next": "^24.2.1",
    "i18next-browser-languagedetector": "^8.0.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.16.0",
    "pg": "^8.13.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vite": "^6.0.7"
  }
}
