{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": true,
    "types": ["vite/client", "node"]
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "hook/**/*.ts",
    "hooks/**/*.ts",
    "types/**/*.ts",
    "validations/**/*.ts",
    "constants/**/*.ts",
    "i18n/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "server",
    "components/app-sidebar.tsx",
    "components/shared/SessionLockDialog.tsx",
    "components/ui/calendar.tsx",
    "components/ui/DateRangePicker.tsx",
    "components/ui/Date.tsx"
  ]
}
